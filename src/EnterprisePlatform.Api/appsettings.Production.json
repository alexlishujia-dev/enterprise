{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "Host=postgres;Port=5432;Database=enterprise;Username=platform;Password=platform123",
    "CommandTimeoutSeconds": 30
  },
  "Jwt": {
    "Issuer": "EnterprisePlatform",
    "Audience": "EnterprisePlatform.Client",
    "SecretKey": "EnterprisePlatform-Prod-Secret-Key-Change-Me-32chars!",
    "ExpireMinutes": 120
  },
  "Cors": {
    "Origins": [ "*" ]
  },
  "FileLog": {
    "Enabled": true,
    "Directory": "logs",
    "FilePrefix": "app-",
    "MinimumLevel": "Error",
    "LogSql": true
  },
  "RequestSign": {
    "Enabled": true,
    "SecretKey": "EnterprisePlatform-Prod-Request-Sign-Key-Change-Me!",
    "TimestampToleranceSeconds": 300,
    "SignResponse": true,
    "SkipPaths": [ "/health", "/swagger", "/uploads", "/api/File" ]
  },
  "FileStorage": {
    "UploadRootPath": "uploads",
    "AvatarSubPath": "avatars",
    "MaxAvatarSizeBytes": 2097152,
    "AllowedAvatarExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".webp" ]
  }
}
