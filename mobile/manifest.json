{
  "name": "EnterprisePlatform",
  "appid": "__UNI__ENTERPRISE_PLATFORM",
  "description": "企业平台移动端 - 对接 ASP.NET Core ADO.NET 后端",
  "versionName": "1.0.0",
  "versionCode": "100",
  "transformPx": false,
  "vueVersion": "3",
  "app-plus": {
    "usingComponents": true,
    "nvueStyleCompiler": "uni-app",
    "compilerVersion": 3,
    "splashscreen": {
      "alwaysShowBeforeRender": true,
      "waiting": true,
      "autoclose": true,
      "delay": 0
    },
    "modules": {},
    "distribute": {
      "android": {
        "permissions": [
          "<uses-permission android:name=\"android.permission.INTERNET\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/>"
        ]
      },
      "ios": {},
      "sdkConfigs": {}
    }
  },
  "mp-weixin": {
    "appid": "",
    "setting": {
      "urlCheck": false,
      "es6": true,
      "minified": true
    },
    "usingComponents": true
  },
  "h5": {
    "router": {
      "mode": "hash"
    },
    "devServer": {
      "port": 5173,
      "https": false,
      "proxy": {
        "/api": {
          "target": "https://localhost:7088",
          "changeOrigin": true,
          "secure": false
        },
        "/uploads": {
          "target": "https://localhost:7088",
          "changeOrigin": true,
          "secure": false
        }
      }
    },
    "title": "EnterprisePlatform"
  }
}
